{
  "expo": {
    "name": "School Manager",
    "slug": "school-manager",
    "description": "Manage your school activities easily, sync with your classmates & teachers.",
    "updates": {
      "url": "https://u.expo.dev/41089c6c-2549-4047-827c-f4b5133ebbcf"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/appicon/SchoolManager-universal-monochrome-1024x1024@1x.png",
    "scheme": "schoolmanager",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/images/appicon/SchoolManager.icon",
      "bundleIdentifier": "com.xarber.schoolmanager",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7088fa",
        "foregroundImage": "./assets/images/appicon/SchoolManager-android-foreground-1024x1024@1x.png",
        "backgroundImage": "./assets/images/appicon/SchoolManager-android-background-1024x1024@1x.png",
        "monochromeImage": "./assets/images/appicon/SchoolManager-android-foreground-1024x1024@1x.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.xarber.schoolmanager"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/appicon/SchoolManager-universal-splash-1024x1024@1x.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/appicon/SchoolManager-universal-splash-1024x1024@1x.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sqlite",
      "expo-background-task",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "it"
            ],
            "android": [
              "en",
              "it"
            ]
          }
        }
      ],
      "expo-llm-mediapipe",
      "./plugins/withAlternateIcons"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41089c6c-2549-4047-827c-f4b5133ebbcf"
      },
      "supportsRTL": true
    }
  }
}
