{
  "expo": {
    "name": "School Manager",
    "slug": "school-manager",
    "description": "Manage your school activities easily, sync with your classmates & teachers.",
    "updates": {
      "url": "https://u.expo.dev/41089c6c-2549-4047-827c-f4b5133ebbcf",
      "enabled": true,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icons/icon-monochrome.png",
    "scheme": "schoolmanager",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icons/icon-default/icon-default.icon",
      "bundleIdentifier": "com.xarber.schoolmanager",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#7088fa",
        "foregroundImage": "./assets/icons/icon-default/icon-default-light-foreground.png",
        "backgroundImage": "./assets/icons/icon-default/icon-default-light-background.png",
        "monochromeImage": "./assets/icons/icon-default/icon-default-light-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.xarber.schoolmanager"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icons/icon-splash.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icons/icon-splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-sqlite",
      "expo-background-task",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "it"
            ],
            "android": [
              "en",
              "it"
            ]
          }
        }
      ],
      "expo-llm-mediapipe",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "IconDefault",
            "iosNew": "./assets/icons/icon-default/icon-default.icon",
            "ios": {
              "light": "./assets/icons/icon-default/icon-default-light.png",
              "dark": "./assets/icons/icon-default/icon-default-dark.png",
              "tinted": "./assets/icons/icon-tinted.png"
            },
            "android": {
              "backgroundColor": "#7088fa",
              "foregroundImage": "./assets/icons/icon-default/icon-default-light-foreground.png",
              "backgroundImage": "./assets/icons/icon-default/icon-default-light-background.png",
              "monochromeImage": "./assets/icons/icon-default/icon-default-light-foreground.png"
            }
          },
          {
            "name": "IconExams",
            "iosNew": "./assets/icons/icon-exams/icon-exams.icon",
            "ios": {
              "light": "./assets/icons/icon-exams/icon-exams-light.png",
              "dark": "./assets/icons/icon-exams/icon-exams-dark.png",
              "tinted": "./assets/icons/icon-tinted.png"
            },
            "android": {
              "backgroundColor": "#3D1F00",
              "foregroundImage": "./assets/icons/icon-exams/icon-exams-light-foreground.png",
              "backgroundImage": "./assets/icons/icon-exams/icon-exams-light-background.png",
              "monochromeImage": "./assets/icons/icon-exams/icon-exams-light-foreground.png"
            }
          },
          {
            "name": "IconRainbow",
            "iosNew": "./assets/icons/icon-rainbow/icon-rainbow.icon",
            "ios": {
              "light": "./assets/icons/icon-rainbow/icon-rainbow-light.png",
              "dark": "./assets/icons/icon-rainbow/icon-rainbow-dark.png",
              "tinted": "./assets/icons/icon-tinted.png"
            },
            "android": {
              "backgroundColor": "#FFFF00",
              "foregroundImage": "./assets/icons/icon-rainbow/icon-rainbow-light-foreground.png",
              "backgroundImage": "./assets/icons/icon-rainbow/icon-rainbow-light-background.png",
              "monochromeImage": "./assets/icons/icon-rainbow/icon-rainbow-light-foreground.png"
            }
          },
          {
            "name": "IconRedgradient",
            "iosNew": "./assets/icons/icon-redgradient/icon-redgradient.icon",
            "ios": {
              "light": "./assets/icons/icon-redgradient/icon-redgradient-light.png",
              "dark": "./assets/icons/icon-redgradient/icon-redgradient-dark.png",
              "tinted": "./assets/icons/icon-tinted.png"
            },
            "android": {
              "backgroundColor": "#E65658",
              "foregroundImage": "./assets/icons/icon-redgradient/icon-redgradient-light-foreground.png",
              "backgroundImage": "./assets/icons/icon-redgradient/icon-redgradient-light-background.png",
              "monochromeImage": "./assets/icons/icon-redgradient/icon-redgradient-light-foreground.png"
            }
          }
        ]
      ],
      "expo-quick-actions"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "41089c6c-2549-4047-827c-f4b5133ebbcf"
      },
      "supportsRTL": true
    }
  }
}
