{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "School Manager",
  "version": "1.0.0",
  "identifier": "com.xarber.schoolmanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:8081",
    "beforeDevCommand": "npx expo start --go",
    "beforeBuildCommand": "npx expo export -p web"
  },
  "app": {
    "windows": [
      {
        "title": "School Manager",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
